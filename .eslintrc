
{
    "env": {
      "es6": true,
      "browser":true
    },
    "extends": "eslint:recommended",
    "parserOptions": {
        "ecmaVersion": 6,
        "sourceType": "module"
    },
    "rules":{
        "quotes": [2,"single"],
        "semi": [2, "always"],
        "no-undef": 0,
        "no-console":0
    }
}
